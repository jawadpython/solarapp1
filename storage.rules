rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Product images: public read (catalog); admin-only write
    match /products/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
                   && request.resource != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Technician certificates: auth required to read; owner or admin to write
    match /technician_certificates/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // User profile images: own or admin to read/write
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Partner documents: auth required to read; owner to write
    match /partner_documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
