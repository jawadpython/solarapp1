# Copy to .env for local testing. On Render, set these in the dashboard.

PORT=8080

# Firebase service account JSON (one line). Firebase Console → Project settings →
# Service accounts → Generate new private key → paste entire JSON here.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Tawfir Energy
# Prefer support@ over noreply@ for better deliverability
RESEND_REPLY_TO=support@yourdomain.com

# Optional: if jawadsoftware.com is connected in Firebase Auth authorized domains
# FIREBASE_AUTH_LINK_DOMAIN=jawadsoftware.com
